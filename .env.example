# Supabase (browser). Use either VITE_* (recommended for Vite) or SUPABASE_* — both are exposed (see vite.config.js).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Anthropic (server only — used by api/ai/* on Vercel and by Vite dev middleware; never VITE_*).
# ANTHROPIC_API_KEY=

# Supabase service role (server only — lets api/* verify auth tokens & write subscription/usage rows).
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe (server only — used by api/stripe/*). Never expose the secret key to the browser.
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...        # from the Stripe webhook endpoint you register at /api/stripe/webhook
# STRIPE_PRICE_PRO_MONTHLY=price_...     # the A$20/mo AUD recurring price ID
# STRIPE_PRICE_PRO_ANNUAL=price_...      # the A$180/yr AUD recurring price ID
