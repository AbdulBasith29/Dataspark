# Supabase (browser). Use either VITE_* (recommended for Vite) or SUPABASE_* — both are exposed (see vite.config.js).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Anthropic (server only — used by api/ai/* on Vercel and by Vite dev middleware; never VITE_*).
# ANTHROPIC_API_KEY=
